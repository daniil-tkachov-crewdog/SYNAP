{
  "name": "synap",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "turbo run dev --filter=@synap/web --filter=@synap/extension",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@synap/web",
    "build:extension": "turbo run build --filter=@synap/extension",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "prettier": "^3.4.2",
    "eslint": "^9.17.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
